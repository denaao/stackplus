generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HOST
  PLAYER
  CASHIER
}

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum TransactionType {
  BUYIN
  REBUY
  ADDON
  CASHOUT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(PLAYER)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hostedGames     HomeGame[]
  memberships     HomeGameMember[]
  transactions    Transaction[]
  cashierSessions Session[]       @relation("CashierSessions")
  playerStates    PlayerSessionState[]
}

model HomeGame {
  id          String   @id @default(uuid())
  name        String
  address     String
  dayOfWeek   String
  startTime   String
  chipValue   Decimal  @db.Decimal(10, 2)
  rules       String?
  joinCode    String   @unique
  hostId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  host     User             @relation(fields: [hostId], references: [id])
  members  HomeGameMember[]
  sessions Session[]
}

model HomeGameMember {
  id         String   @id @default(uuid())
  homeGameId String
  userId     String
  joinedAt   DateTime @default(now())

  homeGame HomeGame @relation(fields: [homeGameId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([homeGameId, userId])
  @@index([homeGameId])
  @@index([userId])
}

model Session {
  id          String        @id @default(uuid())
  homeGameId  String
  cashierId   String?
  status      SessionStatus @default(WAITING)
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  homeGame     HomeGame             @relation(fields: [homeGameId], references: [id])
  cashier      User?                @relation("CashierSessions", fields: [cashierId], references: [id])
  transactions Transaction[]
  playerStates PlayerSessionState[]

  @@index([homeGameId])
  @@index([status])
}

model PlayerSessionState {
  id           String   @id @default(uuid())
  sessionId    String
  userId       String
  chipsIn      Decimal  @default(0) @db.Decimal(10, 2)
  chipsOut     Decimal  @default(0) @db.Decimal(10, 2)
  currentStack Decimal  @default(0) @db.Decimal(10, 2)
  result       Decimal  @default(0) @db.Decimal(10, 2)
  hasCashedOut Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
}

model Transaction {
  id           String          @id @default(uuid())
  sessionId    String
  userId       String
  type         TransactionType
  amount       Decimal         @db.Decimal(10, 2)
  chips        Decimal         @db.Decimal(10, 2)
  note         String?
  registeredBy String
  createdAt    DateTime        @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId, userId])
  @@index([sessionId, type])
  @@index([createdAt])
}
