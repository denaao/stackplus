generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HOST
  PLAYER
  CASHIER
}

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum TransactionType {
  BUYIN
  REBUY
  ADDON
  CASHOUT
  JACKPOT
}

enum GameType {
  CASH_GAME
  TOURNAMENT
}

enum FinancialModule {
  POSTPAID
  PREPAID
  HYBRID
}

enum MemberPaymentMode {
  POSTPAID
  PREPAID
}

enum MemberRole {
  PLAYER
  HOST
  DEALER
  SANGEUR
}

enum SessionFinancialPayoutPurpose {
  SETTLEMENT
  CAIXINHA
}

enum ComandaStatus {
  OPEN
  CLOSED
}

enum ComandaMode {
  PREPAID
  POSTPAID
}

enum ComandaItemType {
  CASH_BUYIN
  CASH_REBUY
  CASH_ADDON
  CASH_CASHOUT
  TOURNAMENT_BUYIN
  TOURNAMENT_REBUY
  TOURNAMENT_ADDON
  TOURNAMENT_BOUNTY_RECEIVED
  TOURNAMENT_PRIZE
  PAYMENT_PIX_SPOT
  PAYMENT_PIX_TERM
  PAYMENT_CASH
  PAYMENT_CARD
  TRANSFER_IN
  TRANSFER_OUT
  CARRY_IN
  CARRY_OUT
  STAFF_CAIXINHA
  STAFF_RAKEBACK
}

enum ComandaItemPaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
}

enum TournamentStatus {
  REGISTRATION
  RUNNING
  ON_BREAK
  FINISHED
  CANCELED
}

enum TournamentPlayerStatus {
  REGISTERED
  ACTIVE
  ELIMINATED
  WINNER
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum SangeurShiftStatus {
  OPEN
  CLOSED
}

enum CashTableStatus {
  OPEN
  CLOSED
}

enum SangeurMovementType {
  INITIAL_LOAD
  RELOAD
  RETURN
}

enum SangeurPaymentMethod {
  PIX_QR
  VOUCHER
  CASH
  CARD
}

enum SangeurPaymentStatus {
  PENDING
  PAID
  CANCELED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  cpf          String   @unique
  phone        String?
  pixType      PixKeyType?
  pixKey       String?
  passwordHash String
  role         Role     @default(PLAYER)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hostedGames     HomeGame[]
  memberships     HomeGameMember[]
  transactions    Transaction[]
  registeredTransactions Transaction[]  @relation("RegisteredTransactions")
  cashierSessions Session[]       @relation("CashierSessions")
  playerStates    PlayerSessionState[]
  sessionStaffAssignments SessionStaff[]
  sessionRakebackAssignments SessionRakeback[]
  sessionParticipantAssignments SessionParticipant[]
  sangeurAccesses HomeGameSangeurAccess[]
  sangeurShifts SangeurShift[] @relation("SangeurOperatorShifts")
  cashTableSeats CashTableSeat[]
  cashTableSangriasCreated CashTableSangria[] @relation("CashTableSangriaCreator")
  sangeurShiftMovementsCreated SangeurShiftMovement[] @relation("SangeurMovementCreator")
  sangeurSalesCreated SangeurSale[] @relation("SangeurSaleCreator")
  sangeurSalesAsPlayer SangeurSale[] @relation("SangeurSalePlayer")
  prepaidChargePendings PrepaidChargePending[]
  sessionFinancialChargePendings SessionFinancialChargePending[]
  sessionFinancialPayoutPendings SessionFinancialPayoutPending[]
  comandas               Comanda[]          @relation("PlayerComandas")
  comandasOpened         Comanda[]          @relation("ComandaOpenedBy")
  comandasClosed         Comanda[]          @relation("ComandaClosedBy")
  comandaItemsCreated    ComandaItem[]      @relation("ComandaItemCreator")
  comandaTransfersCreated ComandaTransfer[] @relation("ComandaTransferCreator")
  tournamentPlayers      TournamentPlayer[]
  auditLogs              AuditLog[]
  refreshTokens          RefreshToken[]
}

// Refresh tokens para rotação de JWT (SEC-004).
//
// Fluxo:
//  - Login emite { accessToken (15min), refreshToken (30d) }
//  - Access token expirou → cliente chama /auth/refresh com refreshToken
//  - /auth/refresh: valida hash, revoga o antigo, emite novo par
//  - Logout: marca tokens do user como revokedAt
//
// O campo `tokenHash` guarda SHA-256 hex do token cru — evita que vazamento
// da tabela exponha tokens válidos. Nunca armazenamos o token em claro.
model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedBy  String?   // id do token novo quando rotaciona (trilha)
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Trilha de auditoria para operações financeiras e administrativas (SEC-008).
// Registros imutáveis — nunca deletar nem update.
// action: código curto da operação (ex: 'TRANSACTION_DELETE', 'HOMEGAME_DELETE').
// resource: nome do modelo afetado ('Transaction', 'HomeGame', etc).
// resourceId: id do recurso (nullable pra operações sem alvo único).
// metadata: dados adicionais em jsonb (amount, chargeId, razão, etc).
// userId: nullable pra eventos de sistema/webhook.
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model HomeGame {
  id                       String   @id @default(uuid())
  name                     String
  gameType                 GameType @default(CASH_GAME)
  financialModule          FinancialModule @default(POSTPAID)
  address                  String
  dayOfWeek                String
  startTime                String
  chipValue                Decimal  @db.Decimal(10, 2)
  jackpotAccumulated       Decimal  @default(0) @db.Decimal(10, 2)
  rules                    String?
  buyInAmount              Decimal? @db.Decimal(10, 2)
  rebuyAmount              Decimal? @db.Decimal(10, 2)
  addOnAmount              Decimal? @db.Decimal(10, 2)
  blindsMinutesBeforeBreak Int?
  blindsMinutesAfterBreak  Int?
  levelsUntilBreak         Int?
  joinCode                 String   @unique
  hostId                   String
  // Saldo da conta bancária virtual do home game. Atualizado automaticamente
  // por PIX confirmado no Annapay (entrada) e PIX de saída ao jogador credor.
  bankBalance              Decimal  @default(0) @db.Decimal(10, 2)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  host     User             @relation(fields: [hostId], references: [id])
  members  HomeGameMember[]
  sangeurAccesses HomeGameSangeurAccess[]
  sangeurShifts SangeurShift[]
  sessions Session[]
  comandas  Comanda[]
  tournaments Tournament[]
  bankTransactions HomeGameBankTransaction[]
}

enum BankTxDirection {
  IN
  OUT
}

model HomeGameBankTransaction {
  id             String           @id @default(uuid())
  homeGameId     String
  direction      BankTxDirection
  amount         Decimal          @db.Decimal(10, 2)
  description    String?
  comandaItemId  String?
  annapayRef     String?
  createdAt      DateTime         @default(now())

  homeGame HomeGame @relation(fields: [homeGameId], references: [id])

  @@index([homeGameId])
  @@index([comandaItemId])
  @@index([createdAt])
}

model HomeGameMember {
  id         String   @id @default(uuid())
  homeGameId String
  userId     String
  paymentMode MemberPaymentMode?
  role       MemberRole @default(PLAYER)
  joinedAt   DateTime @default(now())

  homeGame HomeGame @relation(fields: [homeGameId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([homeGameId, userId])
  @@index([homeGameId])
  @@index([userId])
}

model HomeGameSangeurAccess {
  id             String   @id @default(uuid())
  homeGameId     String
  userId         String
  username       String
  passwordHash   String
  isActive       Boolean  @default(true)
  mustChangePassword Boolean @default(true)
  activationToken          String?   @unique
  activationTokenExpiresAt DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  homeGame HomeGame @relation(fields: [homeGameId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  shifts   SangeurShift[]

  @@unique([homeGameId, userId])
  @@unique([homeGameId, username])
  @@index([homeGameId])
  @@index([userId])
}

model Session {
  id          String        @id @default(uuid())
  homeGameId  String
  name        String?
  pokerVariant String?
  gameType    GameType      @default(CASH_GAME)
  financialModule FinancialModule @default(POSTPAID)
  jackpotEnabled Boolean    @default(false)
  jackpotAccumulated Decimal? @db.Decimal(10, 2)
  chipValue   Decimal?      @db.Decimal(10, 2)
  smallBlind  Decimal?      @db.Decimal(10, 2)
  bigBlind    Decimal?      @db.Decimal(10, 2)
  minimumBuyIn Decimal?     @db.Decimal(10, 2)
  minimumStayMinutes Int?
  foodFee     Decimal?      @db.Decimal(10, 2)
  buyInAmount Decimal?      @db.Decimal(10, 2)
  rebuyAmount Decimal?      @db.Decimal(10, 2)
  addOnAmount Decimal?      @db.Decimal(10, 2)
  blindsMinutesBeforeBreak Int?
  blindsMinutesAfterBreak  Int?
  levelsUntilBreak         Int?
  cashierId   String?
  status      SessionStatus @default(WAITING)
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  homeGame     HomeGame             @relation(fields: [homeGameId], references: [id])
  cashier      User?                @relation("CashierSessions", fields: [cashierId], references: [id])
  transactions Transaction[]
  playerStates PlayerSessionState[]
  staffAssignments SessionStaff[]
  rakebackAssignments SessionRakeback[]
  participantAssignments SessionParticipant[]
  prepaidChargePendings PrepaidChargePending[]
  sessionFinancialChargePendings SessionFinancialChargePending[]
  sessionFinancialPayoutPendings SessionFinancialPayoutPending[]
  sangeurShifts SangeurShift[]
  comandaItems  ComandaItem[]
  tables        CashTable[]

  @@index([homeGameId])
  @@index([status])
  @@index([homeGameId, createdAt])
  @@index([homeGameId, status, finishedAt])
}

model SangeurShift {
  id              String            @id @default(uuid())
  homeGameId      String
  sessionId       String
  sangeurAccessId String
  sangeurUserId   String
  status          SangeurShiftStatus @default(OPEN)
  initialChips    Decimal           @default(0) @db.Decimal(10, 2)
  note            String?
  openedAt        DateTime          @default(now())
  closedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  homeGame      HomeGame              @relation(fields: [homeGameId], references: [id])
  session       Session               @relation(fields: [sessionId], references: [id])
  sangeurAccess HomeGameSangeurAccess @relation(fields: [sangeurAccessId], references: [id])
  sangeurUser   User                  @relation("SangeurOperatorShifts", fields: [sangeurUserId], references: [id])
  movements     SangeurShiftMovement[]
  sales         SangeurSale[]

  @@index([homeGameId])
  @@index([sessionId])
  @@index([sangeurUserId])
  @@index([status])
  @@index([sessionId, sangeurUserId, status])
}

model SangeurShiftMovement {
  id              String             @id @default(uuid())
  shiftId         String
  type            SangeurMovementType
  chips           Decimal            @db.Decimal(10, 2)
  note            String?
  createdByUserId String
  createdAt       DateTime           @default(now())

  shift     SangeurShift @relation(fields: [shiftId], references: [id])
  createdBy User         @relation("SangeurMovementCreator", fields: [createdByUserId], references: [id])

  @@index([shiftId])
  @@index([type])
  @@index([createdAt])
}

model SangeurSale {
  id               String              @id @default(uuid())
  shiftId          String
  sessionUserId    String?
  transactionId    String?             @unique
  chips            Decimal             @db.Decimal(10, 2)
  chipValue        Decimal             @db.Decimal(10, 2)
  amount           Decimal             @db.Decimal(10, 2)
  paymentMethod    SangeurPaymentMethod
  paymentStatus    SangeurPaymentStatus @default(PAID)
  paymentReference String?
  voucherCode      String?
  playerName       String?
  note             String?
  signatureData    String?
  settledAt        DateTime?
  createdByUserId  String
  createdAt        DateTime            @default(now())

  shift        SangeurShift @relation(fields: [shiftId], references: [id])
  createdBy    User         @relation("SangeurSaleCreator", fields: [createdByUserId], references: [id])
  sessionUser  User?        @relation("SangeurSalePlayer", fields: [sessionUserId], references: [id])
  transaction  Transaction? @relation("SangeurSaleTransaction", fields: [transactionId], references: [id])

  @@index([shiftId])
  @@index([paymentMethod])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([paymentMethod, paymentReference, paymentStatus])
  @@index([sessionUserId])
}

model SessionParticipant {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model SessionRakeback {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  percent   Decimal  @default(0) @db.Decimal(5, 2)
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model SessionStaff {
  id             String   @id @default(uuid())
  sessionId      String
  userId         String
  caixinhaAmount Decimal? @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model PlayerSessionState {
  id           String   @id @default(uuid())
  sessionId    String
  userId       String
  chipsIn      Decimal  @default(0) @db.Decimal(10, 2)
  chipsOut     Decimal  @default(0) @db.Decimal(10, 2)
  result       Decimal  @default(0) @db.Decimal(10, 2)
  hasCashedOut Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([userId, updatedAt])
  @@index([sessionId, result])
}

model Transaction {
  id           String          @id @default(uuid())
  sessionId    String
  tableId      String?
  userId       String
  type         TransactionType
  amount       Decimal         @db.Decimal(10, 2)
  chips        Decimal         @db.Decimal(10, 2)
  note          String?
  signatureData String?
  registeredBy String
  // 'C' (cashier) | 'S' (sangeur). DATA-001 Deploy B: NOT NULL + check constraint.
  origin       String
  createdAt    DateTime        @default(now())

  session          Session    @relation(fields: [sessionId], references: [id])
  table            CashTable? @relation(fields: [tableId], references: [id])
  user             User       @relation(fields: [userId], references: [id])
  registeredByUser User       @relation("RegisteredTransactions", fields: [registeredBy], references: [id])
  sangeurSale      SangeurSale? @relation("SangeurSaleTransaction")

  @@index([sessionId, userId])
  @@index([tableId])
  @@index([sessionId, type])
  @@index([createdAt])
  @@index([sessionId, createdAt])
  @@index([sessionId, userId, createdAt])
  // PERF: historico do jogador cross-session (ranking, stats globais).
  @@index([userId, createdAt])
  // DATA-001 Deploy B: acelera join via FK em registeredBy.
  @@index([registeredBy])
}

model PrepaidChargePending {
  id           String          @id @default(uuid())
  chargeId     String          @unique
  sessionId    String
  userId       String
  virtualAccount String?
  type         TransactionType
  chips        Decimal         @db.Decimal(10, 2)
  amount       Decimal         @db.Decimal(10, 2)
  registeredBy String
  status       String          @default("PENDING")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([status])
}

model SessionFinancialChargePending {
  id             String   @id @default(uuid())
  chargeId       String
  sessionId      String
  userId         String
  virtualAccount String?
  amount         Decimal  @db.Decimal(10, 2)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([chargeId])
  @@index([status])
}

model SessionFinancialPayoutPending {
  id             String                       @id @default(uuid())
  sessionId      String
  userId         String
  purpose        SessionFinancialPayoutPurpose
  payoutOrderId  String
  virtualAccount String?
  amount         Decimal                      @db.Decimal(10, 2)
  status         String                       @default("PENDING")
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId, purpose])
  @@unique([payoutOrderId])
  @@index([status])
}

// ─── COMANDA ────────────────────────────────────────────────────────────────

model Comanda {
  id             String        @id @default(uuid())
  playerId       String
  homeGameId     String
  status         ComandaStatus @default(OPEN)
  mode           ComandaMode   @default(PREPAID)
  creditLimit    Decimal?      @db.Decimal(10, 2)
  balance        Decimal       @default(0) @db.Decimal(10, 2)
  note           String?
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  openedByUserId String
  closedByUserId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  player           User              @relation("PlayerComandas", fields: [playerId], references: [id])
  homeGame         HomeGame          @relation(fields: [homeGameId], references: [id])
  openedBy         User              @relation("ComandaOpenedBy", fields: [openedByUserId], references: [id])
  closedBy         User?             @relation("ComandaClosedBy", fields: [closedByUserId], references: [id])
  items            ComandaItem[]
  tournamentPlayers TournamentPlayer[]

  @@index([playerId])
  @@index([homeGameId])
  @@index([status])
  @@index([playerId, homeGameId, status])
  // PERF: listagem de comandas do home game filtrando por status (OPEN/CLOSED).
  @@index([homeGameId, status])
}

model ComandaItem {
  id                    String                    @id @default(uuid())
  comandaId             String
  type                  ComandaItemType
  amount                Decimal                   @db.Decimal(10, 2)
  description           String?
  sessionId             String?
  tournamentId          String?
  tournamentPlayerId    String?
  transactionId         String?
  paymentReference      String?
  paymentStatus         ComandaItemPaymentStatus?
  paymentVirtualAccount String?
  createdByUserId       String
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  comanda          Comanda           @relation(fields: [comandaId], references: [id])
  createdBy        User              @relation("ComandaItemCreator", fields: [createdByUserId], references: [id])
  session          Session?          @relation(fields: [sessionId], references: [id])
  tournament       Tournament?       @relation("TournamentComandaItems", fields: [tournamentId], references: [id])
  tournamentPlayer TournamentPlayer? @relation(fields: [tournamentPlayerId], references: [id])
  transferAsSource ComandaTransfer?  @relation("TransferSourceItem")
  transferAsDest   ComandaTransfer?  @relation("TransferDestItem")

  @@index([comandaId])
  @@index([type])
  @@index([tournamentId])
  @@index([sessionId])
  @@index([paymentStatus])
  @@index([paymentReference])
  // PERF: relatorio cashbox filtra por periodo (createdAt range).
  @@index([createdAt])
  // PERF: load de comanda busca itens pendentes especificamente.
  @@index([comandaId, paymentStatus])
  // PERF: reconcile global por (paymentStatus PAID, type IN PIX_*).
  @@index([paymentStatus, type])
}

model ComandaTransfer {
  id              String   @id @default(uuid())
  sourceItemId    String   @unique
  destItemId      String   @unique
  reason          String?
  createdByUserId String
  createdAt       DateTime @default(now())

  sourceItem ComandaItem @relation("TransferSourceItem", fields: [sourceItemId], references: [id])
  destItem   ComandaItem @relation("TransferDestItem", fields: [destItemId], references: [id])
  createdBy  User        @relation("ComandaTransferCreator", fields: [createdByUserId], references: [id])
}

// ─── TOURNAMENT ─────────────────────────────────────────────────────────────

model Tournament {
  id                       String           @id @default(uuid())
  homeGameId               String
  name                     String
  status                   TournamentStatus @default(REGISTRATION)

  buyInAmount              Decimal          @db.Decimal(10, 2)
  rebuyAmount              Decimal?         @db.Decimal(10, 2)
  addonAmount              Decimal?         @db.Decimal(10, 2)
  bountyAmount             Decimal?         @db.Decimal(10, 2)
  rake                     Decimal          @default(0) @db.Decimal(5, 2)

  startingChips            Int
  rebuyChips               Int?
  addonChips               Int?

  lateRegistrationLevel    Int?
  rebuyUntilLevel          Int?
  addonAfterLevel          Int?

  minutesPerLevelPreLateReg  Int              @default(15)
  minutesPerLevelPostLateReg Int?
  breaks                     String?
  buyInTaxAmount             Decimal?         @db.Decimal(10, 2)
  buyInTaxChips              Int?
  rebuyTaxAmount             Decimal?         @db.Decimal(10, 2)
  rebuyTaxChips              Int?
  addonTaxAmount             Decimal?         @db.Decimal(10, 2)
  addonTaxChips              Int?
  blindTemplateName          String?
  doubleBuyInBonusChips      Int?

  currentLevel             Int              @default(0)
  levelStartedAt           DateTime?
  isOnBreak                Boolean          @default(false)
  breakStartedAt           DateTime?
  isPaused                 Boolean          @default(false)
  pausedAt                 DateTime?
  dealPayouts              String?
  payoutStructure          String?
  doubleRebuyEnabled       Boolean          @default(false)
  prizePool                Decimal          @default(0) @db.Decimal(10, 2)
  totalRake                Decimal          @default(0) @db.Decimal(10, 2)
  totalTax                 Decimal          @default(0) @db.Decimal(10, 2)

  startedAt                DateTime?
  finishedAt               DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  homeGame    HomeGame               @relation(fields: [homeGameId], references: [id])
  blindLevels TournamentBlindLevel[]
  players     TournamentPlayer[]
  comandaItems ComandaItem[]         @relation("TournamentComandaItems")

  @@index([homeGameId])
  @@index([status])
  @@index([homeGameId, status])
}

model TournamentBlindLevel {
  id           String     @id @default(uuid())
  tournamentId String
  level        Int
  smallBlind   Int
  bigBlind     Int
  ante         Int        @default(0)

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, level])
  @@index([tournamentId])
}

model TournamentPlayer {
  id                   String                 @id @default(uuid())
  tournamentId         String
  playerId             String
  comandaId            String
  status               TournamentPlayerStatus @default(REGISTERED)
  position             Int?
  rebuysCount          Int                    @default(0)
  hasAddon             Boolean                @default(false)
  bountyCollected      Decimal                @default(0) @db.Decimal(10, 2)
  prizeAmount          Decimal?               @db.Decimal(10, 2)
  eliminatedByPlayerId String?
  eliminatedAtLevel    Int?
  registeredAt         DateTime               @default(now())
  eliminatedAt         DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  tournament   Tournament        @relation(fields: [tournamentId], references: [id])
  player       User              @relation(fields: [playerId], references: [id])
  comanda      Comanda           @relation(fields: [comandaId], references: [id])
  eliminatedBy TournamentPlayer? @relation("EliminationRelation", fields: [eliminatedByPlayerId], references: [id])
  eliminations TournamentPlayer[] @relation("EliminationRelation")
  comandaItems ComandaItem[]

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([playerId])
  @@index([status])
}

// ─── CASH TABLES ────────────────────────────────────────────────────────────

// Mesa individual dentro de uma Session de cash game.
// Uma Session pode ter várias mesas abertas simultaneamente.
// Rake e caixinha são acumulados e retirados via CashTableSangria.
model CashTable {
  id           String          @id @default(uuid())
  sessionId    String
  name         String          @default("Mesa 1")
  status       CashTableStatus @default(OPEN)
  caixinhaMode String          @default("SPLIT")
  rake         Decimal         @default(0) @db.Decimal(10, 2)
  caixinha     Decimal         @default(0) @db.Decimal(10, 2)
  jackpot      Decimal         @default(0) @db.Decimal(10, 2)
  openedAt     DateTime        @default(now())
  closedAt     DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  session      Session            @relation(fields: [sessionId], references: [id])
  seats        CashTableSeat[]
  sangrias     CashTableSangria[]
  transactions Transaction[]

  @@index([sessionId])
  @@index([status])
  @@index([sessionId, status])
}

// Jogador numa mesa específica. Rastreia stack atual por mesa.
// Um jogador pode ter seats em mesas diferentes (ao longo do tempo),
// mas normalmente está ativo em apenas uma por vez.
model CashTableSeat {
  id           String    @id @default(uuid())
  tableId      String
  userId       String
  currentStack Decimal   @default(0) @db.Decimal(10, 2)
  hasCashedOut Boolean   @default(false)
  seatedAt     DateTime  @default(now())
  cashedOutAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  table CashTable @relation(fields: [tableId], references: [id])
  user  User      @relation(fields: [userId], references: [id])

  @@unique([tableId, userId])
  @@index([tableId])
  @@index([userId])
  @@index([tableId, hasCashedOut])
}

// Retirada de rake e/ou caixinha de uma mesa.
// Pode ocorrer múltiplas vezes durante o jogo (sangria parcial).
// Quando isFinal = true e todos os seats têm hasCashedOut = true,
// a mesa é fechada automaticamente.
model CashTableSangria {
  id              String    @id @default(uuid())
  tableId         String
  rake            Decimal   @default(0) @db.Decimal(10, 2)
  caixinha        Decimal   @default(0) @db.Decimal(10, 2)
  jackpot         Decimal   @default(0) @db.Decimal(10, 2)
  isFinal         Boolean   @default(false)
  note            String?
  createdByUserId String
  createdAt       DateTime  @default(now())

  table     CashTable @relation(fields: [tableId], references: [id])
  createdBy User      @relation("CashTableSangriaCreator", fields: [createdByUserId], references: [id])

  @@index([tableId])
  @@index([tableId, isFinal])
  @@index([createdAt])
}
