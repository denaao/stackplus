generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HOST
  PLAYER
  CASHIER
}

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum TransactionType {
  BUYIN
  REBUY
  ADDON
  CASHOUT
  JACKPOT
}

enum GameType {
  CASH_GAME
  TOURNAMENT
}

enum FinancialModule {
  POSTPAID
  PREPAID
  HYBRID
}

enum MemberPaymentMode {
  POSTPAID
  PREPAID
}

enum SessionFinancialPayoutPurpose {
  SETTLEMENT
  CAIXINHA
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum WhatsAppProvider {
  EVOLUTION
}

enum WhatsAppInstanceStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  RECEIVED
  FAILED
}

enum SangeurShiftStatus {
  OPEN
  CLOSED
}

enum SangeurMovementType {
  INITIAL_LOAD
  RELOAD
  RETURN
}

enum SangeurPaymentMethod {
  PIX_QR
  VOUCHER
  CASH
  CARD
}

enum SangeurPaymentStatus {
  PENDING
  PAID
  CANCELED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  cpf          String?  @unique
  phone        String?
  pixType      PixKeyType?
  pixKey       String?
  passwordHash String
  role         Role     @default(PLAYER)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hostedGames     HomeGame[]
  memberships     HomeGameMember[]
  transactions    Transaction[]
  cashierSessions Session[]       @relation("CashierSessions")
  playerStates    PlayerSessionState[]
  sessionStaffAssignments SessionStaff[]
  sessionRakebackAssignments SessionRakeback[]
  sessionParticipantAssignments SessionParticipant[]
  sangeurAccesses HomeGameSangeurAccess[]
  sangeurShifts SangeurShift[] @relation("SangeurOperatorShifts")
  sangeurShiftMovementsCreated SangeurShiftMovement[] @relation("SangeurMovementCreator")
  sangeurSalesCreated SangeurSale[] @relation("SangeurSaleCreator")
  prepaidChargePendings PrepaidChargePending[]
  sessionFinancialChargePendings SessionFinancialChargePending[]
  sessionFinancialPayoutPendings SessionFinancialPayoutPending[]
}

model WhatsAppInstanceConfig {
  id               String                 @id @default(uuid())
  provider         WhatsAppProvider       @default(EVOLUTION)
  instanceName     String                 @unique
  apiBaseUrl       String
  enabled          Boolean                @default(true)
  status           WhatsAppInstanceStatus @default(DISCONNECTED)
  phoneNumber      String?
  qrCodeBase64     String?
  webhookSecret    String?
  lastConnectionAt DateTime?
  lastError        String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  messageLogs WhatsAppMessageLog[]
}

model WhatsAppMessageLog {
  id                String                   @id @default(uuid())
  instanceConfigId  String
  externalMessageId String?
  event             String?
  direction         WhatsAppMessageDirection @default(OUTBOUND)
  status            WhatsAppMessageStatus    @default(PENDING)
  recipientPhone    String?
  senderPhone       String?
  messageText       String?
  payload           Json?
  errorMessage      String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  instanceConfig WhatsAppInstanceConfig @relation(fields: [instanceConfigId], references: [id])

  @@index([instanceConfigId, createdAt])
  @@index([externalMessageId])
  @@index([status])
}

model HomeGame {
  id                       String   @id @default(uuid())
  name                     String
  gameType                 GameType @default(CASH_GAME)
  financialModule          FinancialModule @default(POSTPAID)
  address                  String
  dayOfWeek                String
  startTime                String
  chipValue                Decimal  @db.Decimal(10, 2)
  jackpotAccumulated       Decimal  @default(0) @db.Decimal(10, 2)
  rules                    String?
  buyInAmount              Decimal? @db.Decimal(10, 2)
  rebuyAmount              Decimal? @db.Decimal(10, 2)
  addOnAmount              Decimal? @db.Decimal(10, 2)
  blindsMinutesBeforeBreak Int?
  blindsMinutesAfterBreak  Int?
  levelsUntilBreak         Int?
  joinCode                 String   @unique
  hostId                   String
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  host     User             @relation(fields: [hostId], references: [id])
  members  HomeGameMember[]
  sangeurAccesses HomeGameSangeurAccess[]
  sangeurShifts SangeurShift[]
  sessions Session[]
}

model HomeGameMember {
  id         String   @id @default(uuid())
  homeGameId String
  userId     String
  paymentMode MemberPaymentMode?
  joinedAt   DateTime @default(now())

  homeGame HomeGame @relation(fields: [homeGameId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([homeGameId, userId])
  @@index([homeGameId])
  @@index([userId])
}

model HomeGameSangeurAccess {
  id             String   @id @default(uuid())
  homeGameId     String
  userId         String
  username       String
  passwordHash   String
  isActive       Boolean  @default(true)
  mustChangePassword Boolean @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  homeGame HomeGame @relation(fields: [homeGameId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  shifts   SangeurShift[]

  @@unique([homeGameId, userId])
  @@unique([homeGameId, username])
  @@index([homeGameId])
  @@index([userId])
}

model Session {
  id          String        @id @default(uuid())
  homeGameId  String
  pokerVariant String?
  gameType    GameType      @default(CASH_GAME)
  financialModule FinancialModule @default(POSTPAID)
  jackpotEnabled Boolean    @default(false)
  chipValue   Decimal?      @db.Decimal(10, 2)
  smallBlind  Decimal?      @db.Decimal(10, 2)
  bigBlind    Decimal?      @db.Decimal(10, 2)
  minimumBuyIn Decimal?     @db.Decimal(10, 2)
  minimumStayMinutes Int?
  foodFee     Decimal?      @db.Decimal(10, 2)
  buyInAmount Decimal?      @db.Decimal(10, 2)
  rebuyAmount Decimal?      @db.Decimal(10, 2)
  addOnAmount Decimal?      @db.Decimal(10, 2)
  blindsMinutesBeforeBreak Int?
  blindsMinutesAfterBreak  Int?
  levelsUntilBreak         Int?
  cashierId   String?
  rake        Decimal?      @db.Decimal(10, 2)
  caixinha    Decimal?      @db.Decimal(10, 2)
  status      SessionStatus @default(WAITING)
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  homeGame     HomeGame             @relation(fields: [homeGameId], references: [id])
  cashier      User?                @relation("CashierSessions", fields: [cashierId], references: [id])
  transactions Transaction[]
  playerStates PlayerSessionState[]
  staffAssignments SessionStaff[]
  rakebackAssignments SessionRakeback[]
  participantAssignments SessionParticipant[]
  prepaidChargePendings PrepaidChargePending[]
  sessionFinancialChargePendings SessionFinancialChargePending[]
  sessionFinancialPayoutPendings SessionFinancialPayoutPending[]
  sangeurShifts SangeurShift[]

  @@index([homeGameId])
  @@index([status])
}

model SangeurShift {
  id              String            @id @default(uuid())
  homeGameId      String
  sessionId       String
  sangeurAccessId String
  sangeurUserId   String
  status          SangeurShiftStatus @default(OPEN)
  initialChips    Decimal           @default(0) @db.Decimal(10, 2)
  note            String?
  openedAt        DateTime          @default(now())
  closedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  homeGame      HomeGame              @relation(fields: [homeGameId], references: [id])
  session       Session               @relation(fields: [sessionId], references: [id])
  sangeurAccess HomeGameSangeurAccess @relation(fields: [sangeurAccessId], references: [id])
  sangeurUser   User                  @relation("SangeurOperatorShifts", fields: [sangeurUserId], references: [id])
  movements     SangeurShiftMovement[]
  sales         SangeurSale[]

  @@index([homeGameId])
  @@index([sessionId])
  @@index([sangeurUserId])
  @@index([status])
}

model SangeurShiftMovement {
  id              String             @id @default(uuid())
  shiftId         String
  type            SangeurMovementType
  chips           Decimal            @db.Decimal(10, 2)
  note            String?
  createdByUserId String
  createdAt       DateTime           @default(now())

  shift     SangeurShift @relation(fields: [shiftId], references: [id])
  createdBy User         @relation("SangeurMovementCreator", fields: [createdByUserId], references: [id])

  @@index([shiftId])
  @@index([type])
  @@index([createdAt])
}

model SangeurSale {
  id               String              @id @default(uuid())
  shiftId          String
  chips            Decimal             @db.Decimal(10, 2)
  chipValue        Decimal             @db.Decimal(10, 2)
  amount           Decimal             @db.Decimal(10, 2)
  paymentMethod    SangeurPaymentMethod
  paymentStatus    SangeurPaymentStatus @default(PAID)
  paymentReference String?
  voucherCode      String?
  playerName       String?
  note             String?
  settledAt        DateTime?
  createdByUserId  String
  createdAt        DateTime            @default(now())

  shift     SangeurShift @relation(fields: [shiftId], references: [id])
  createdBy User         @relation("SangeurSaleCreator", fields: [createdByUserId], references: [id])

  @@index([shiftId])
  @@index([paymentMethod])
  @@index([paymentStatus])
  @@index([createdAt])
}

model SessionParticipant {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model SessionRakeback {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  percent   Decimal  @default(0) @db.Decimal(5, 2)
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model SessionStaff {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}

model PlayerSessionState {
  id           String   @id @default(uuid())
  sessionId    String
  userId       String
  chipsIn      Decimal  @default(0) @db.Decimal(10, 2)
  chipsOut     Decimal  @default(0) @db.Decimal(10, 2)
  currentStack Decimal  @default(0) @db.Decimal(10, 2)
  result       Decimal  @default(0) @db.Decimal(10, 2)
  hasCashedOut Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([sessionId])
}

model Transaction {
  id           String          @id @default(uuid())
  sessionId    String
  userId       String
  type         TransactionType
  amount       Decimal         @db.Decimal(10, 2)
  chips        Decimal         @db.Decimal(10, 2)
  note         String?
  registeredBy String
  createdAt    DateTime        @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId, userId])
  @@index([sessionId, type])
  @@index([createdAt])
}

model PrepaidChargePending {
  id           String          @id @default(uuid())
  chargeId     String          @unique
  sessionId    String
  userId       String
  virtualAccount String?
  type         TransactionType
  chips        Decimal         @db.Decimal(10, 2)
  amount       Decimal         @db.Decimal(10, 2)
  registeredBy String
  status       String          @default("PENDING")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([status])
}

model SessionFinancialChargePending {
  id             String   @id @default(uuid())
  chargeId       String
  sessionId      String
  userId         String
  virtualAccount String?
  amount         Decimal  @db.Decimal(10, 2)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([chargeId])
  @@index([status])
}

model SessionFinancialPayoutPending {
  id             String                       @id @default(uuid())
  sessionId      String
  userId         String
  purpose        SessionFinancialPayoutPurpose
  payoutOrderId  String
  virtualAccount String?
  amount         Decimal                      @db.Decimal(10, 2)
  status         String                       @default("PENDING")
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId, purpose])
  @@unique([payoutOrderId])
  @@index([status])
}
